<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark Racing Theme -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/accent_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Overrides para remover o roxo padrão do Material3 (ex: Chips selecionados) -->
        <item name="colorPrimaryContainer">#4DFF6D00</item> <!-- Laranja Escuro Transparente -->
        <item name="colorOnPrimaryContainer">@color/accent_primary</item>
        <item name="colorSecondaryContainer">#4DFF6D00</item>
        <item name="colorOnSecondaryContainer">@color/accent_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <style name="Theme.AppMobile" parent="Base.Theme.AppMobile" />

    <!-- Botão primário racing orange -->
    <style name="RacingButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Botão secundário outline -->
    <style name="RacingButtonOutline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Card escuro -->
    <style name="DarkCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>
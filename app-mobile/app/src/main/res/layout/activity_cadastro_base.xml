<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/logo_app" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Novo Projeto"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Nome do Projeto -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nome do Projeto"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editTextNomeProjeto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Track Day Civic"
            android:inputType="text"
            android:minHeight="48dp"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/bg_input"
            android:padding="12dp" />

        <!-- Marca -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Marca"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerMarcas"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_input"
            android:padding="8dp" />

        <!-- Modelo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modelo"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerModelos"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_input"
            android:padding="8dp" />

        <!-- Orçamento -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Orçamento (R$)"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editTextOrcamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: 15000"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/bg_input"
            android:padding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonProximo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Próximo →"
            android:textSize="16sp"
            style="@style/RacingButton"
            android:layout_marginTop="24dp" />

    </LinearLayout>
</ScrollView>
